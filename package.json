{
  "name": "finahue-bot",
  "version": "1.0.0",
  "description": "Finahue - bot de Telegram para finanzas personales de una pareja, con Google Sheets como base de datos, corriendo en Cloudflare Workers.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "register-webhook": "tsx scripts/register-webhook.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "@types/node": "^26.1.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  }
}
